static const test_file_t* current_active_file = NULL;
static size_t current_offset = 0;

// data callback
int raw_feature_get_data(size_t offset, size_t length, float *out_ptr) {
    if (!current_active_file) return -1;
    size_t effective_offset = current_offset + offset;
    
    if (effective_offset + length > current_active_file->data_len) {
        return -1; 
    }
    
    memcpy(out_ptr, current_active_file->data_ptr + effective_offset, length * sizeof(float));
    return 0;
}


int ml_run() {
    LOG_INF("### ML Multi-File Accuracy Test Started ###");

    const uint32_t SLIDE_STEP_MS = 50;
    const uint32_t NUM_AXES = 6;
    uint32_t samples_to_slide = SLIDE_STEP_MS / EI_CLASSIFIER_INTERVAL_MS;
    uint32_t slide_step_floats = samples_to_slide * NUM_AXES;

    // Accuracy Tracking
    int total_windows_global = 0;
    int correct_windows_global = 0;

    signal_t signal;
    signal.total_length = EI_CLASSIFIER_DSP_INPUT_FRAME_SIZE;
    signal.get_data = &raw_feature_get_data;

    // Loop through each file
    for (int i = 0; i < ARRAY_SIZE(all_test_files); i++) {
        current_active_file = &all_test_files[i];
        current_offset = 0;
        
        int file_windows = 0;
        int file_correct = 0;

        LOG_INF(">> Testing File [%d/%zu]: %s", i + 1, ARRAY_SIZE(all_test_files), current_active_file->file_name);
        LOG_INF("   Expected Label: %s", current_active_file->expected_label);

        // Slide window through the current file
        while (current_offset + EI_CLASSIFIER_DSP_INPUT_FRAME_SIZE <= current_active_file->data_len) {
            ei_impulse_result_t result = { 0 };

            EI_IMPULSE_ERROR res = run_classifier(&signal, &result, false);
            if (res != EI_IMPULSE_OK) {
                LOG_ERR("Classifier error %d", res);
                break;
            }

            // Find label with highest confidence
            size_t max_ix = 0;
            float max_val = 0.0f;
            for (size_t ix = 0; ix < EI_CLASSIFIER_LABEL_COUNT; ix++) {
                if (result.classification[ix].value > max_val) {
                    max_val = result.classification[ix].value;
                    max_ix = ix;
                }
            }

            const char* predicted_label = result.classification[max_ix].label;

            // Update Accuracy
            file_windows++;
            total_windows_global++;
            
            if (strcmp(predicted_label, current_active_file->expected_label) == 0) {
                file_correct++;
                correct_windows_global++;
            }

            // Slide the window
            current_offset += slide_step_floats;
            
            // Minimal sleep to prevent watchdog or logging bottlenecks
            k_yield();
        }

        float file_acc = (file_windows > 0) ? ((float)file_correct / file_windows) * 100.0f : 0;
        LOG_INF("   File Result: %d/%d correct (%.2f%%)", file_correct, file_windows, (double)file_acc);
    }

    LOG_INF("=======================================");
    LOG_INF("FINAL ACCURACY REPORT");
    LOG_INF("Total Windows Processed: %d", total_windows_global);
    LOG_INF("Total Correct Windows:   %d", correct_windows_global);
    
    if (total_windows_global > 0) {
        float total_accuracy = ((float)correct_windows_global / total_windows_global) * 100.0f;
        LOG_INF("OVERALL SYSTEM ACCURACY: %.2f%%", (double)total_accuracy);
    } else {
        LOG_WRN("No data was processed.");
    }
    LOG_INF("=======================================");

    return 0;
}
